---
interface Project {
    title: string;
    status: string;
    description: string;
    tags: string[];
    github: string;
    demo?: string;
    projectIcons: { tag: string; icon: string }[];
}

const projects = [
    // Row 1: Web Development
    {
        title: "Modern Esthete",
        status: "shipped",
        description: "Modern e-commerce interface focusing on clean design and user experience.",
        tags: ["TypeScript", "Next.js", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/Modern-Esthete",
        demo: "https://modernesthete.vercel.app/"
    },
    {
        title: "CollabData",
        status: "shipped",
        description: "Collaborative platform for data analysis and information visualization.",
        tags: ["TypeScript", "Next.js", "Tailwind CSS", "Firebase"],
        github: "https://github.com/Devsebastian44/CollabData",
        demo: "https://collabdata.vercel.app/"
    },
    {
        title: "DevBlog",
        status: "shipped",
        description: "Blog focusing on programming, cybersecurity, and data science and AI",
        tags: ["Astro", "TypeScript", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/DevBlog",
        demo: "https://devblog44.vercel.app/"
    },
    // Row 2: Data Science
    {
        title: "Alura Store",
        status: "shipped",
        description: "Analysis of sales, performance, and customer satisfaction for Alura Store branches.",
        tags: ["Python", "Pandas", "Matplotlib", "Seaborn"],
        github: "https://github.com/Devsebastian44/Alura-Store",
        demo: "https://github.com/devsebastian44/Challenge-Data-Science/blob/main/Challenge_Alura_Latam.ipynb"
    },
    {
        title: "Telecom X",
        status: "shipped",
        description: "Customer churn analysis to optimize retention through data science.",
        tags: ["Python", "Pandas", "NumPy", "Matplotlib", "Seaborn"],
        github: "https://github.com/devsebastian44/Challenge-Telecom-X",
        demo: "https://github.com/devsebastian44/Challenge-Telecom-X/blob/main/TelecomX_LATAM.ipynb"
    },
    {
        title: "Telecom X 2",
        status: "shipped",
        description: "Machine Learning pipeline to predict customer churn and optimize retention strategies.",
        tags: ["Python", "Scikit-learn", "Pandas", "Matplotlib", "Seaborn"],
        github: "https://github.com/devsebastian44/Telecom-X-2",
        demo: "https://github.com/devsebastian44/Telecom-X-2/blob/main/TelecomX_Churn_ML.ipynb"
    },
    // Row 3: Cybersecurity
    {
        title: "Keylogger",
        status: "shipped",
        description: "Educational keylogger framework and research tool with integrated DevSecOps pipeline.",
        tags: ["Python", "DevSecOps", "SAST", "Pytest"],
        github: "https://github.com/devsebastian44/Keylogger"
    },
    {
        title: "Reverse Shell",
        status: "shipped",
        description: "Remote access and persistence strategy for Windows 10 under DevSecOps standards.",
        tags: ["Python", "PowerShell", "DevSecOps", "Windows 10"],
        github: "https://github.com/devsebastian44/Reverse-Shell"
    },
    {
        title: "Sandboxed",
        status: "shipped",
        description: "Tool menu for malware and computer virus analysis in controlled environments.",
        tags: ["Bash", "Python", "Kali Linux", "REMnux"],
        github: "https://github.com/devsebastian44/Sandboxed"
    }
];

const techIcons: Record<string, string> = {
    "TypeScript": "https://cdn.simpleicons.org/typescript/FFFFFF",
    "Next.js": "https://cdn.simpleicons.org/nextdotjs/FFFFFF",
    "Tailwind CSS": "https://cdn.simpleicons.org/tailwindcss/FFFFFF",
    "Astro": "https://cdn.simpleicons.org/astro/FFFFFF",
    "Python": "https://cdn.simpleicons.org/python/FFFFFF",
    "Scikit-learn": "https://cdn.simpleicons.org/scikitlearn/FFFFFF",
    "Pandas": "https://cdn.simpleicons.org/pandas/FFFFFF",
    "Matplotlib": "https://api.iconify.design/devicon-plain/matplotlib.svg?color=white",
    "Seaborn": "https://api.iconify.design/devicon-plain/seaborn.svg?color=white",
    "Bash": "https://cdn.simpleicons.org/gnubash/FFFFFF",
    "Apache": "https://api.iconify.design/logos/apache.svg?color=white",
    "Ubuntu Server": "https://cdn.simpleicons.org/ubuntu/FFFFFF",
    "Linux": "https://cdn.simpleicons.org/linux/FFFFFF",
    "React": "https://cdn.simpleicons.org/react/FFFFFF",
    "PostgreSQL": "https://cdn.simpleicons.org/postgresql/FFFFFF",
    "MySQL": "https://cdn.simpleicons.org/mysql/FFFFFF",
    "Binance API": "https://cdn.simpleicons.org/binance/FFFFFF",
    "Firebase": "https://cdn.simpleicons.org/firebase/FFFFFF",
    "NumPy": "https://cdn.simpleicons.org/numpy/FFFFFF",
    "BeautifulSoup": "https://cdn.simpleicons.org/python/FFFFFF",
    "Requests": "https://cdn.simpleicons.org/python/FFFFFF",
    "Integración Continua": "https://cdn.simpleicons.org/gitlab/FFFFFF",
    "DevSecOps": "https://api.iconify.design/mdi/shield-check.svg?color=white",
    "PowerShell": "https://api.iconify.design/simple-icons/powershell.svg?color=white",
    "SAST": "https://api.iconify.design/mdi/magnify-scan.svg?color=white",
    "Pytest": "https://cdn.simpleicons.org/pytest/FFFFFF",
    "Windows 10": "https://api.iconify.design/simple-icons/windows.svg?color=white",
    "Kali Linux": "https://cdn.simpleicons.org/kalilinux/FFFFFF",
    "REMnux": "https://api.iconify.design/mdi/virus-outline.svg?color=white",
    "CI/CD": "https://cdn.simpleicons.org/gitlab/FFFFFF"
};

const projectsWithIcons: Project[] = projects.map(project => {
    const projectIcons: { tag: string; icon: string }[] = [];
    const seenIcons = new Set<string>();
    project.tags.forEach(tag => {
        const icon = techIcons[tag];
        if (icon && !seenIcons.has(icon)) {
            seenIcons.add(icon);
            projectIcons.push({ tag, icon });
        }
    });
    return { ...project, projectIcons } as Project;
});
---

<section id="projects" class="py-24 relative bg-transparent">
    <!-- Projects Background Glow -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] h-[600px] bg-[#00ffa3]/5 blur-[120px] rounded-full pointer-events-none z-0"
    >
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                My <span class="text-[#00ffa3]">Projects</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                A collection of my best work, where creativity meets code.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            {projectsWithIcons.map((project) => (
                <div class="group relative bg-white/[0.02] backdrop-blur-xl border border-white/10 rounded-2xl p-8 flex flex-col gap-6 transition-all duration-300 hover:border-[#00ffa3]/30 hover:bg-white/[0.04] hover:shadow-[0_0_30px_rgba(0,255,163,0.05)] overflow-hidden">
                    <!-- Tech background subtle deco -->
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity">
                         <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>
                    </div>

                    <!-- Header Row: Icon & Status -->
                    <div class="flex items-center justify-between relative z-10">
                        <div class="flex items-center justify-center w-10 h-10 bg-[#00ffa3]/10 rounded-xl border border-[#00ffa3]/20 group-hover:border-[#00ffa3]/50 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1 bg-[#00ffa3]/5 border border-[#00ffa3]/10 rounded-full">
                            <div class="w-1.5 h-1.5 rounded-full bg-[#00ffa3] animate-pulse shadow-[0_0_8px_rgba(0,255,163,0.5)]"></div>
                            <span class="text-[10px] font-mono text-[#00ffa3] font-bold uppercase tracking-wider">{project.status}</span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="relative z-10 space-y-4">
                        <h3 class="text-2xl font-bold text-white tracking-tight group-hover:text-[#00ffa3] transition-colors leading-tight">
                            {project.title}
                        </h3>
                        <p class="text-slate-400 text-sm leading-relaxed line-clamp-3">
                            {project.description}
                        </p>
                    </div>


                    <!-- Tech Icons -->
                    <div class="flex flex-wrap gap-4 pt-4 border-t border-white/5 relative z-10 mt-auto">
                        {project.projectIcons.map(({ tag, icon }) => (
                            <div class="group/tech relative w-8 h-8 flex items-center justify-center">
                                <img 
                                    src={icon} 
                                    alt={tag}
                                    class="w-6 h-6 object-contain opacity-70 hover:opacity-100 hover:text-[#00ffa3] transition-all duration-300 transform hover:scale-110 grayscale brightness-[300%]"
                                    title={tag}
                                />
                                <!-- Custom Tooltip -->
                                <span class="absolute -top-8 left-1/2 -translate-x-1/2 px-2 py-1 bg-black/90 border border-white/10 rounded text-[10px] text-[#00ffa3] opacity-0 group-hover/tech:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-20">
                                    {tag}
                                </span>
                            </div>
                        ))}
                    </div>

                    <!-- Action Links -->
                    <div class="flex items-center gap-6 pt-2 relative z-10">
                        {project.github && (
                            <a href={project.github} target="_blank" class="flex items-center gap-2 text-[11px] font-mono text-slate-500 hover:text-white transition-all group/link" aria-label="GitHub Repository">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:text-[#00ffa3] transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                source
                            </a>
                        )}
                        {project.demo && (
                            <a href={project.demo} target="_blank" class="flex items-center gap-2 text-[11px] font-mono text-white/70 hover:text-white transition-all group/link relative" aria-label="Live Demo">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                <span class="relative">
                                    live demo
                                    <span class="absolute -bottom-1 left-0 w-full h-[2px] bg-[#00ffa3] shadow-[0_0_10px_rgba(0,255,163,0.8)] opacity-0 group-hover/link:opacity-100 transition-all duration-300"></span>
                                </span>
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>

        <!-- More Projects Button -->
        <div class="mt-20 flex justify-center relative z-10">
            <a 
                href="https://github.com/Devsebastian44" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group/github flex items-center gap-3 px-10 py-4 bg-white/[0.03] border border-white/10 rounded-2xl text-white hover:border-[#00ffa3]/50 hover:shadow-[0_0_30px_rgba(34,197,94,0.15)] transition-all duration-300 transform hover:-translate-y-1"
            >
                <span class="text-slate-300 group-hover/github:text-white transition-colors uppercase text-xs font-bold tracking-widest">More projects on</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3] group-hover/github:scale-110 transition-transform">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
            </a>
        </div>
    </div>
    
    <!-- Decorative background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[1000px] h-[1000px] bg-[#00ffa3]/5 rounded-full blur-[150px] md:blur-[200px] -z-10"></div>
</section>
