---
const currentYear = new Date().getFullYear();
const socialLinks = [
    { name: "github", url: "https://github.com/Devsebastian44" },
    { name: "linkedin", url: "https://www.linkedin.com/in/devsebastian44" },
];
---

<footer
    class="pt-16 pb-10 relative border-t border-white/10 bg-white/[0.02] backdrop-blur-xl"
>
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[600px] h-[200px] md:h-[300px] bg-[#00ffa3]/5 blur-[70px] md:blur-[100px] rounded-full pointer-events-none z-0"
    >
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-7xl mx-auto">
            <div
                class="flex flex-col md:flex-row justify-center gap-12 md:gap-20 mb-12"
            >
                <!-- Left Side: Brand & Bio -->
                <div class="max-w-md space-y-8">
                    <div class="space-y-6">
                        <a
                            href="/"
                            class="text-2xl font-bold text-white tracking-tighter flex items-center gap-2"
                        >
                            <img
                                src="/Img/favicon.png"
                                alt="DevSebastian Logo"
                                class="w-8 h-8 object-contain drop-shadow-[0_0_12px_rgba(0, 255, 163, 0.6)]"
                            />
                            DevSebastian
                        </a>
                        <p class="text-slate-400 text-sm leading-relaxed">
                            Creating digital experiences with clean code,
                            creativity, and a passion for innovation.
                        </p>
                    </div>

                    <div class="flex gap-6">
                        {
                            socialLinks.map((social) => (
                                <a
                                    href={social.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-slate-500 hover:text-[#00ffa3] transition-colors"
                                >
                                    <span class="sr-only">{social.name}</span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        {social.name === "github" && (
                                            <>
                                                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                                <path d="M9 18c-4.51 2-5-2-7-2" />
                                            </>
                                        )}
                                        {social.name === "linkedin" && (
                                            <>
                                                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                                <rect
                                                    width="4"
                                                    height="12"
                                                    x="2"
                                                    y="9"
                                                />
                                                <circle cx="4" cy="4" r="2" />
                                            </>
                                        )}
                                    </svg>
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Right Side: Navigation -->
                <div class="">
                    <h4
                        class="text-white font-bold tracking-widest text-sm mb-6 uppercase"
                    >
                        Navigation
                    </h4>
                    <ul class="space-y-4">
                        <li>
                            <a
                                href="/en#about"
                                class="text-slate-400 hover:text-[#00ffa3] text-sm transition-colors flex items-center gap-2 group/nav"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-[#00ffa3]/50 group-hover/nav:text-[#00ffa3] transition-colors"
                                    ><path
                                        d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                                    ></path><circle cx="12" cy="7" r="4"
                                    ></circle></svg
                                >
                                About
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en#projects"
                                class="text-slate-400 hover:text-[#00ffa3] text-sm transition-colors flex items-center gap-2 group/nav"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-[#00ffa3]/50 group-hover/nav:text-[#00ffa3] transition-colors"
                                    ><polyline points="4 17 10 11 4 5"
                                    ></polyline><line
                                        x1="12"
                                        y1="19"
                                        x2="20"
                                        y2="19"></line></svg
                                >
                                Projects
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en#certifications"
                                class="text-slate-400 hover:text-[#00ffa3] text-sm transition-colors flex items-center gap-2 group/nav"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-[#00ffa3]/50 group-hover/nav:text-[#00ffa3] transition-colors"
                                    ><circle cx="12" cy="8" r="7"
                                    ></circle><polyline
                                        points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"
                                    ></polyline></svg
                                >
                                Certifications
                            </a>
                        </li>

                        <li>
                            <a
                                href="/en#contact"
                                class="text-slate-400 hover:text-[#00ffa3] text-sm transition-colors flex items-center gap-2 group/nav"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-[#00ffa3]/50 group-hover/nav:text-[#00ffa3] transition-colors"
                                    ><line x1="22" y1="2" x2="11" y2="13"
                                    ></line><polygon
                                        points="22 2 15 22 11 13 2 9 22 2"
                                    ></polygon></svg
                                >
                                Contact
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div
                class="pt-6 border-t border-white/5 flex flex-col justify-center items-center text-center gap-2"
            >
                <div class="text-slate-500 text-xs font-medium leading-relaxed">
                    Copyright © 2025 Sebastian Zhunaula. All rights reserved.
                </div>
            </div>
        </div>
    </div>
</footer>
