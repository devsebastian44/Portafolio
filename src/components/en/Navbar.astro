---
const navLinks = [
    {
        name: "Home",
        href: "#home",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>`,
    },
    {
        name: "About",
        href: "#about",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`,
    },
    {
        name: "Experience",
        href: "#experience",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>`,
    },
    {
        name: "Projects",
        href: "#projects",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>`,
    },
    {
        name: "Certifications",
        href: "#certifications",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>`,
    },
    {
        name: "Contact",
        href: "#contact",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3]/50 group-hover:text-[#00ffa3] transition-colors"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>`,
    },
];
---

<header
    x-data="{ isOpen: false }"
    class="fixed top-0 left-0 right-0 z-50 px-4 md:px-8 pt-2 transition-all duration-300"
>
    <nav
        class="max-w-[1440px] mx-auto flex flex-wrap md:flex-nowrap items-center justify-between gap-4 relative z-10 px-4"
    >
        <!-- Brand / Logo Box -->
        <a href="/" class="nav-terminal-box px-6 py-3 group gap-3">
            <div class="relative flex items-center justify-center">
                <div
                    class="absolute inset-0 bg-[#00ffa3]/20 blur-md rounded-full group-hover:bg-[#00ffa3]/30 transition-colors duration-500"
                >
                </div>
                <img
                    src="/Img/favicon.png"
                    alt="DevSebastian Logo"
                    class="w-8 h-8 object-contain group-hover:rotate-12 transition-transform duration-500 relative z-10"
                />
            </div>
            <span
                class="text-xl md:text-2xl font-black text-white tracking-tighter uppercase font-['Aldrich'] group-hover:text-[#00ffa3] transition-colors"
            >
                DevSebastian<span class="text-[#00ffa3]">.exe</span>
            </span>
        </a>

        <!-- Desktop Nav Box -->
        <div class="!hidden md:!flex nav-terminal-box overflow-hidden">
            <div class="flex items-center">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class="nav-link-terminal border-r border-black/10 last:border-r-0"
                        >
                            {link.name.toUpperCase()}
                        </a>
                    ))
                }
            </div>

            <!-- Action Button & Language Switcher -->
            <div
                class="flex items-center border-l-2 border-white/10 ml-2 h-full"
            >
                <a
                    href="/"
                    class="px-6 py-4 bg-[#00ffa3] text-black font-mono font-bold text-[12px] uppercase hover:bg-white transition-all rounded-l-none"
                >
                    ES_ES
                </a>
            </div>
        </div>

        <!-- Mobile Controls (Visible only on mobile) -->
        <div class="flex md:hidden items-center gap-2">
            <button
                class="nav-terminal-box p-3 focus:outline-none group bg-black hover:bg-[#00ffa3] transition-colors"
                style="box-shadow: 4px 4px 0px #00ffa3;"
                @click="isOpen = !isOpen"
            >
                <div class="flex flex-col gap-1.5">
                    <div
                        class="w-8 h-[2px] bg-[#00ffa3] group-hover:bg-black transition-all"
                    >
                    </div>
                    <div
                        class="w-10 h-[2px] bg-white group-hover:bg-black transition-all"
                    >
                    </div>
                    <div
                        class="w-6 h-[2px] bg-[#00ffa3] group-hover:bg-black transition-all ml-auto"
                    >
                    </div>
                </div>
            </button>
        </div>
    </nav>

    <!-- Mobile Nav Overlay -->
    <div
        x-show="isOpen"
        x-cloak
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-x-full"
        x-transition:enter-end="opacity-100 translate-x-0"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-x-0"
        x-transition:leave-end="opacity-0 translate-x-full"
        class="fixed inset-0 z-[200] md:hidden bg-black w-full h-[100dvh] flex flex-col"
    >
        <!-- Grid Background Overlay -->
        <div
            class="absolute inset-0 bg-grid-cyber opacity-20 pointer-events-none"
        >
        </div>

        <!-- Menu Header -->
        <div
            class="relative z-10 flex items-center justify-between px-10 py-8 border-b border-[#00ffa3]/20 bg-black"
        >
            <div class="flex flex-col">
                <span
                    class="text-[10px] font-mono text-[#00ffa3] tracking-[0.3em] uppercase opacity-70"
                    >Access_Granted</span
                >
                <span
                    class="text-2xl font-black text-white tracking-widest uppercase font-['Aldrich']"
                    >SYSTEM_MENU</span
                >
            </div>
            <button
                @click="isOpen = false"
                class="text-[#00ffa3] hover:bg-[#00ffa3]/10 transition-colors p-3 bg-white/5 rounded-none border border-[#00ffa3]/30"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Navigation Links -->
        <div
            class="relative z-10 flex-1 overflow-y-auto py-12 px-10 flex flex-col gap-8"
        >
            <div class="flex flex-col gap-4">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            @click="isOpen = false"
                            class="group flex items-center justify-between p-5 bg-white/[0.02] border border-white/10 rounded-none text-lg font-black font-mono tracking-[0.1em] text-white hover:border-[#00ffa3]/50 hover:bg-[#00ffa3]/5 transition-all duration-300"
                        >
                            <div class="flex items-center gap-4">
                                <span class="text-[#00ffa3] opacity-50 group-hover:opacity-100 transition-opacity">
                                    <Fragment set:html={link.icon} />
                                </span>
                                {link.name.toUpperCase()}
                            </div>
                            <div class="w-2 h-2 bg-[#00ffa3] opacity-0 group-hover:opacity-100 transition-opacity" />
                        </a>
                    ))
                }
            </div>

            <!-- Language Switcher Section -->
            <div class="mt-8 pt-8 border-t border-white/10">
                <p
                    class="text-[10px] font-mono uppercase tracking-[0.4em] text-[#00ffa3]/50 mb-6"
                >
                    _Switch_Environment
                </p>
                <a
                    href="/"
                    @click="isOpen = false"
                    class="flex items-center justify-center gap-4 w-full py-5 bg-[#00ffa3]/10 border border-[#00ffa3]/30 text-[#00ffa3] font-black font-mono text-center hover:bg-[#00ffa3] hover:text-black transition-all uppercase tracking-[0.2em] text-xs shadow-[0_0_20px_rgba(0,255,163,0.1)]"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="12" cy="12" r="10"></circle><line
                            x1="2"
                            y1="12"
                            x2="22"
                            y2="12"></line><path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                        ></path></svg
                    >
                    Spanish_Kernel
                </a>
            </div>
        </div>

        <!-- Social Footer -->
        <div
            class="relative z-10 px-10 py-8 border-t border-white/10 bg-black/50"
        >
            <div class="flex items-center justify-between">
                <p
                    class="text-[10px] font-mono text-slate-500 uppercase tracking-widest leading-none"
                >
                    Social Connect
                </p>
                <div class="flex gap-4">
                    <a
                        href="https://github.com/devsebastian44"
                        target="_blank"
                        class="p-3 bg-white/5 border border-white/10 rounded-xl text-slate-400 hover:text-[#00ffa3] hover:border-[#00ffa3]/30 transition-all"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://linkedin.com/in/devsebastian44"
                        target="_blank"
                        class="p-3 bg-white/5 border border-white/10 rounded-xl text-slate-400 hover:text-[#00ffa3] hover:border-[#00ffa3]/30 transition-all"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"
                            ></path><circle cx="4" cy="4" r="2"></circle></svg
                        >
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>
