        <script>
            const terminalValues = [
                { id: "terminal-experiments", text: "12" },
                { id: "terminal-status-main", text: "forging" },
                { id: "terminal-spark", text: "today" },
            ];

            function typeWriter(
                element: HTMLElement,
                text: string,
                speed: number = 40,
            ) {
                let i = 0;
                element.innerHTML = ""; // Start empty
                const cursor = document.createElement("span");
                cursor.className = "terminal-cursor";
                element.appendChild(cursor);

                return new Promise<void>((resolve) => {
                    function type() {
                        if (i < text.length) {
                            const charNode = document.createTextNode(
                                text.charAt(i),
                            );
                            element.insertBefore(charNode, cursor);
                            i++;
                            setTimeout(type, speed);
                        } else {
                            cursor.remove(); // Optional: remove cursor when finished
                            resolve();
                        }
                    }
                    type();
                });
            }

            async function runTerminalAnimation() {
                for (const item of terminalValues) {
                    const el = document.getElementById(item.id);
                    if (el) {
                        await typeWriter(el, item.text);
                    }
                }
            }

            const observerOptions = {
                root: null,
                rootMargin: "0px",
                threshold: 0.1,
            };

            let animationStarted = false;
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting && !animationStarted) {
                        animationStarted = true;
                        runTerminalAnimation();
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            const aboutSection = document.getElementById("about");
            if (aboutSection) {
                observer.observe(aboutSection);
            }
        </script>
