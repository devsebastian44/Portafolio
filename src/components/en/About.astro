<section id="about" class="py-24 relative bg-transparent">
    <div class="relative z-10">
        <!-- Tech Ticker -->
        <div
            class="relative w-full py-4 mb-24 overflow-hidden bg-white/[0.02] backdrop-blur-sm border-y border-white/5"
        >
            <!-- Continuous Marquee Container -->
            <div class="flex whitespace-nowrap animate-ticker w-max">
                {
                    // Define the unique set of technologies once
                    Array.from({ length: 2 }).map((_) => (
                        <div class="flex items-center">
                            {[
                                "Python",
                                "PHP",
                                "TypeScript",
                                "Kotlin",
                                "C Sharp",
                                "React",
                                "Angular",
                                "Astro",
                                "TailwindCSS",
                                "Next.js",
                                "Node.js",
                                "Laravel",
                                "Go",
                                "Elixir",
                                "PostgreSQL",
                                "MySQL",
                                "MongoDB",
                                "Redis",
                                "Supabase",
                                "Firebase",
                                "Prisma",
                                "AWS",
                                "Docker",
                                "Jenkins",
                                "Git",
                                "GitLab",
                                "Vercel",
                                "Pandas",
                                "NumPy",
                                "Plotly",
                                "Matplotlib",
                                "Seaborn",
                                "Kali Linux",
                                "REMnux",
                                "OWASP",
                                "Nessus",
                                "OpenVAS",
                                "Statsmodels",
                                "SciPy",
                                "Scikit-learn",
                                "Snort",
                            ].map((techName) => (
                                <div class="flex items-center gap-4 px-8 transition-all duration-300 hover:scale-110 cursor-default opacity-80 hover:opacity-100">
                                    {sphereIconMap[techName] && (
                                        <img
                                            src={sphereIconMap[techName]}
                                            alt={techName}
                                            class="w-6 h-6 brightness-0 invert"
                                        />
                                    )}
                                    <span class="text-xs font-mono text-slate-300 font-medium uppercase tracking-widest">
                                        {techName}
                                    </span>
                                </div>
                            ))}
                        </div>
                    ))
                }
            </div>
            <!-- Fade Edges -->
            <div
                class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-black to-transparent z-10"
            >
            </div>
            <div
                class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-black to-transparent z-10"
            >
            </div>
        </div>

        <!-- Header -->
        <div class="container mx-auto px-6 mb-16 text-center relative z-10">
            <h2
                class="text-3xl md:text-5xl font-bold text-white mb-4 flex items-center justify-center gap-2"
            >
                About <span class="text-[#00ffa3]">Me</span>
            </h2>
            <p
                class="text-slate-400 text-sm md:text-base max-w-3xl mx-auto leading-relaxed"
            >
                Passionate developer with a love for clean code, great coffee,
                and open-source contributions.
            </p>
        </div>

        <div class="container mx-auto px-6">
            <!-- Dashboard Grid -->
            <div class="max-w-6xl mx-auto">
                <!-- Bio & Photo Section -->
                <div
                    class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-4"
                >
                    <!-- Left: About Me Text -->
                    <div class="bg-card p-6 relative flex flex-col group">
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-[#00ffa3]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
                        >
                        </div>
                        <div class="flex items-center gap-3 mb-6 relative z-10">
                            <div
                                class="p-2.5 bg-[#00ffa3]/10 rounded-xl text-[#00ffa3]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
