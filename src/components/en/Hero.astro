---

---

<section
  id="home"
  class="relative min-h-screen flex items-center pt-28 pb-20 w-full overflow-hidden"
>
  <!-- Hero Glows -->
  <div
    class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-[#00ffa3]/5 blur-[80px] md:blur-[120px] rounded-full z-0 pointer-events-none"
  >
  </div>
  <div
    class="absolute top-1/2 right-1/4 -translate-y-1/2 w-[250px] md:w-[500px] h-[250px] md:h-[500px] bg-[#00ffa3]/5 blur-[80px] md:blur-[100px] rounded-full z-0 pointer-events-none hidden md:block"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div
      class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24 max-w-6xl mx-auto"
    >
      <!-- Left Column: Content -->
      <div class="flex-1 text-left space-y-8">
        <div>
          <div class="status-online mb-6">
            <span></span> SYSTEM ONLINE
          </div>

          <h2 class="text-3xl md:text-4xl text-slate-500 mb-2 font-mono">
            Hello World! I'm
          </h2>
          <h1
            class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] tracking-tighter sm:whitespace-nowrap"
          >
            Sebastian <span class="text-[#00ffa3] block sm:inline"
              >Zhunaula</span
            >
          </h1>
        </div>

        <div class="space-y-4">
          <div
            class="flex items-center gap-3 text-[#00ffa3] font-mono text-xl md:text-2xl font-bold"
          >
            <span>$</span>
            <span id="typing-role">Web Developer</span>
            <span class="cursor-blink"></span>
          </div>

          <p
            class="text-slate-400 max-w-xl text-base md:text-lg leading-relaxed"
          >
            Developer with experience in multiple technological areas, including
            web development, cybersecurity, and data science.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href="https://github.com/devsebastian44"
            target="_blank"
            class="btn-terminal-solid"
          >
            GITHUB_INITIALIZE.exe
          </a>
          <a
            href="https://linkedin.com/in/devsebastian44"
            target="_blank"
            class="btn-terminal-outline"
          >
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"
              ></path><circle cx="4" cy="4" r="2"></circle></svg
            >
            LINKEDIN_SESSION.sh
          </a>
        </div>
      </div>

      <!-- Right Column: Image in Terminal Frame -->
      <div class="flex-1 w-full max-w-xl relative group">
        <!-- Terminal Window -->
        <div
          class="relative bg-black border border-white/10 rounded-lg overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] transition-all duration-500 group-hover:scale-[1.02]"
        >
          <!-- Rainbow Border Highlight -->
          <div
            class="absolute -inset-[1px] bg-gradient-to-tr from-[#00dc82]/20 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity"
          >
          </div>

          <!-- Terminal Header -->
          <div
            class="flex items-center justify-between px-4 py-2 bg-[#0a0a0a] border-b border-white/5 relative z-10"
          >
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
              <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
            </div>
            <div
              class="text-[10px] text-slate-500 font-mono tracking-widest uppercase"
            >
              profile_pic.png
            </div>
            <div class="w-10"></div>
          </div>

          <!-- Main Image -->
          <div
            class="aspect-square relative overflow-hidden bg-slate-900 group"
          >
            <img
              src="/Img/Foto.jpeg"
              alt="Sebastian Zhunaula"
              class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700"
            />
            <!-- Scanline Overlay -->
            <div
              class="absolute inset-0 pointer-events-none opacity-[0.03] bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]"
            >
            </div>
          </div>
        </div>

        <!-- Terminal Glow Background -->
        <div
          class="absolute -inset-4 bg-[#00ffa3]/10 blur-3xl rounded-full -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>
      </div>
    </div>
  </div>

  <style>
    .cursor-blink {
      display: inline-block;
      width: 10px;
      height: 24px;
      background-color: #00ffa3;
      margin-left: 4px;
      animation: blink 1s step-end infinite;
      vertical-align: middle;
    }

    @keyframes blink {
      0%,
      100% {
        opacity: 1;
      }
      50% {
        opacity: 0;
      }
    }
  </style>

  <script>
    const roles = [
      "Web Developer",
      "Cybersecurity Specialist",
      "Data Scientist",
    ];
    let roleIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const typingElement = document.getElementById("typing-role");

    function type() {
      if (!typingElement) return;

      const currentRole = roles[roleIndex];

      if (isDeleting) {
        typingElement.textContent = currentRole.substring(0, charIndex - 1);
        charIndex--;
      } else {
        typingElement.textContent = currentRole.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 50 : 100;

      if (!isDeleting && charIndex === currentRole.length) {
        typeSpeed = 2000; // Wait at end
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        typeSpeed = 500;
      }

      setTimeout(type, typeSpeed);
    }

    document.addEventListener("DOMContentLoaded", () => {
      if (typingElement) type();
    });
  </script>
</section>
