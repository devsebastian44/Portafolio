---
const experience = [
    {
        title: "ANALISTA DE CIBERSEGURIDAD FREELANCE",
        company: "@ TRABAJO_AUTÓNOMO",
        period: "2023 - PRESENTE",
        description: [
            "Realización de pruebas de penetración y evaluaciones de seguridad en aplicaciones web.",
            "Identificación y explotación ética de vulnerabilidades críticas (OWASP Top 10).",
            "Implementación de medidas preventivas y auditorías de seguridad proactivas.",
            "Consultoría en hardening de sistemas y mejores prácticas de seguridad digital."
        ]
    },
    {
        title: "FREELANCE FULL-STACK DEVELOPER",
        company: "@ TRABAJO_AUTÓNOMO",
        period: "2022 - PRESENTE",
        description: [
            "Desarrollo de aplicaciones web responsivas e interactivas utilizando HTML5, CSS3 y JavaScript.",
            "Desarrollo de aplicaciones web modernas con React, Next.js y Node.js.",
            "Creación de soluciones web personalizadas adaptadas a los requisitos del cliente.",
            "Integración de principios de seguridad desde el diseño hasta la implementación (DevSecOps)."
        ]
    }
];
---

<section id="experience" class="py-24 relative bg-transparent overflow-hidden">
    <!-- Experience Background Glow -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] h-[600px] bg-[#00ffa3]/5 blur-[120px] rounded-full pointer-events-none z-0"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <!-- Header -->
        <div class="mb-20 flex flex-col items-center text-center">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 flex items-center justify-center gap-2">
                Mis <span class="text-[#00ffa3]">Experiencias</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Un recorrido por mi trayectoria profesional, los retos que he superado y las soluciones que he aportado.
            </p>
        </div>

        <div class="relative max-w-5xl mx-auto">
            <!-- Timeline Line -->
            <div class="absolute left-[15px] top-0 bottom-0 w-[2px] bg-white/10 hidden md:block"></div>

            <!-- Experience Items Container -->
            <div class="flex flex-col gap-16 pt-4">
                {experience.map((item, index) => (
                    <div class="flex gap-8 md:gap-12 relative group">
                        <!-- Timeline Marker -->
                        <div class="hidden md:flex w-8 justify-center relative z-10 pt-1">
                            <div class="w-6 h-6 bg-[#00ffa3] border-2 border-black shadow-[4px_4px_0px_rgba(0,255,163,0.3)] transition-all duration-300 group-hover:scale-110 group-hover:rotate-45 group-hover:bg-[#00ffa3] group-hover:shadow-[4px_4px_0px_#00ffa3]"></div>
                        </div>

                        <!-- Card -->
                        <div class="flex-1 bg-white/[0.02] backdrop-blur-xl border border-white/10 rounded-xl p-8 relative transition-all duration-500 hover:border-[#00ffa3]/30 hover:bg-white/[0.04] group-hover:shadow-[0_0_40px_rgba(0,255,163,0.05)] overflow-hidden">

                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 relative z-10">
                                <h3 class="text-lg md:text-2xl font-black text-white tracking-widest uppercase font-['Aldrich'] group-hover:text-[#00ffa3] transition-colors leading-tight">
                                    {item.title}
                                </h3>
                                <div class="whitespace-nowrap btn-exe !px-4 !py-1.5 !text-[10px] md:!text-xs !tracking-widest !gap-0 shadow-[3px_3px_0px_rgba(255,255,255,0.9)]">
                                    {item.period}
                                </div>
                            </div>

                            <div class="border-t border-dashed border-white/20 pt-6 mb-8 relative z-10">
                                <p class="text-[#00ffa3] font-bold text-sm md:text-base tracking-[0.2em] font-mono uppercase flex items-center gap-2">
                                    <span class="text-[#00ffa3]/50">@</span> {item.company.replace('@ ', '')}
                                </p>
                            </div>

                            <ul class="space-y-4 relative z-10">
                                {item.description.map(bullet => (
                                    <li class="flex items-start gap-4 text-slate-400 text-sm md:text-base leading-relaxed group/item transition-colors hover:text-slate-200">
                                        <div class="min-w-[6px] h-[6px] bg-[#00ffa3]/50 rounded-full mt-2 group-hover/item:bg-[#00ffa3] group-hover/item:scale-125 transition-all"></div>
                                        <span>{bullet}</span>
                                    </li>
                                ))}
                            </ul>

                            <!-- Decorative background icon -->
                            <div class="absolute -bottom-6 -right-6 w-32 h-32 opacity-[0.03] group-hover:opacity-[0.08] transition-all duration-700 pointer-events-none group-hover:rotate-12 group-hover:scale-110">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="0.5">
                                    <path d="M12 2v20M2 12h20M12 2l-4 4M12 2l4 4M12 22l-4-4M12 22l4-4M2 12l4-4M2 12l4 4M22 12l-4-4M22 12l4 4"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
