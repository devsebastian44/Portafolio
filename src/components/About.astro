---

<section id="about" class="pb-24 relative overflow-hidden bg-transparent">
    <div class="relative z-10">
        <!-- Tech Ticker -->
        <div
            class="relative w-full py-4 mb-16 overflow-hidden bg-card !rounded-none border-x-0 border-y border-white/10"
        >
            <!-- Continuous Marquee Container -->
            <div class="flex whitespace-nowrap animate-ticker w-max">
                {
                    // Define the unique set of technologies once
                    Array.from({ length: 2 }).map((_) => (
                        <div class="flex items-center">
                            {[
                                { name: "Python", icon: "python" },
                                { name: "PHP", icon: "php" },
                                { name: "JavaScript", icon: "javascript" },
                                { name: "TypeScript", icon: "typescript" },
                                { name: "Kotlin", icon: "kotlin" },
                                { name: "C Sharp", icon: "csharp" },
                                { name: "HTML5", icon: "html5" },
                                { name: "CSS3", icon: "css3" },
                                { name: "React", icon: "react" },
                                { name: "Angular", icon: "angularjs" },
                                { name: "Astro", icon: "astro" },
                                { name: "Bootstrap", icon: "bootstrap" },
                                { name: "TailwindCSS", icon: "tailwindcss" },
                                { name: "jQuery", icon: "jquery" },
                                { name: "Pandas", icon: "pandas" },
                                { name: "Node.js", icon: "nodejs" },
                                { name: "Laravel", icon: "laravel" },
                                { name: "PostgreSQL", icon: "postgresql" },
                                { name: "MySQL", icon: "mysql" },
                                { name: "MongoDB", icon: "mongodb" },
                                { name: "Docker", icon: "docker" },
                                { name: "Git", icon: "git" },
                                { name: "Jenkins", icon: "jenkins" },
                                { name: "Bash", icon: "bash" },
                                { name: "Figma", icon: "figma" },
                            ].map((tech) => (
                                <div class="flex items-center gap-4 px-8 transition-all duration-300 hover:scale-110 cursor-default opacity-80 hover:opacity-100">
                                    <img
                                        src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.icon}/${tech.icon}-original.svg`}
                                        alt={tech.name}
                                        class="w-6 h-6"
                                    />
                                    <span class="text-xs font-mono text-slate-300 font-medium uppercase tracking-widest">
                                        {tech.name}
                                    </span>
                                </div>
                            ))}
                        </div>
                    ))
                }
            </div>
            <!-- Fade Edges -->
            <div
                class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-black to-transparent z-10"
            >
            </div>
            <div
                class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-black to-transparent z-10"
            >
            </div>
        </div>

        <!-- Header -->
        <div class="container mx-auto px-6 mb-16 text-center relative z-10">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                Sobre <span class="text-[#00ffa3]">Mí</span>
            </h2>
            <p
                class="text-slate-400 text-sm md:text-base max-w-3xl mx-auto leading-relaxed"
            >
                Desarrollador apasionado con amor por el código limpio, el buen
                café y las contribuciones al código abierto.
            </p>
        </div>

        <div class="container mx-auto px-6">
            <!-- Dashboard Grid -->
            <div class="max-w-6xl mx-auto">
                <!-- Bio & Photo Section -->
                <div
                    class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-4"
                >
                    <!-- Left: Sobre mí Text -->
                    <div class="bg-card p-6 relative flex flex-col group">
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-[#00ffa3]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
                        >
                        </div>
                        <div class="flex items-center gap-3 mb-6 relative z-10">
                            <div
                                class="p-2.5 bg-[#00ffa3]/10 rounded-xl text-[#00ffa3]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                                    ></path><circle cx="12" cy="7" r="4"
                                    ></circle></svg
                                >
                            </div>
                            <h4 class="text-lg font-bold text-white">
                                Quien soy
                            </h4>
                        </div>
                        <div
                            class="space-y-4 text-slate-400 text-sm leading-relaxed mb-8 relative z-10"
                        >
                            <p>
                                Soy desarrollador Full-stack con experiencia en
                                la creación de aplicaciones web modernas y
                                eficientes utilizando JavaScript, React y Astro.
                            </p>
                            <p>
                                Me enfoco en buenas prácticas de desarrollo,
                                rendimiento y una experiencia de usuario sólida
                                tanto en frontend como en backend.
                            </p>
                            <p>
                                Cuento con conocimientos en ciberseguridad
                                aplicados a la protección de sistemas y
                                aplicaciones, integrando principios de seguridad
                                desde el diseño hasta la implementación.
                            </p>
                            <p>
                                Además, desarrollo proyectos en ciencia de datos
                                e inteligencia artificial, con énfasis en
                                modelos predictivos e ingeniería de prompts,
                                integrando estas áreas para construir soluciones
                                tecnológicas completas, seguras e innovadoras.
                            </p>
                        </div>
                        <!-- Download CV Button -->
                        <div class="mt-auto relative z-10 flex justify-start">
                            <a
                                href="/CV.pdf"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group/cv flex items-center gap-3 px-8 py-3 bg-[#00ffa3]/10 border border-[#00ffa3]/30 rounded-xl text-[#00ffa3] hover:border-[#00ffa3]/50 hover:bg-[#00ffa3]/20 hover:shadow-[0_0_20px_rgba(0, 255, 163, 0.2)] transition-all duration-300 transform hover:-translate-y-1"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-[#00ffa3] group-hover/cv:scale-110 transition-transform"
                                    ><path
                                        d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                                    ></path><polyline points="14 2 14 8 20 8"
                                    ></polyline></svg
                                >
                                <span class="font-bold tracking-wide"
                                    >Descargar CV</span
                                >
                            </a>
                        </div>
                    </div>

                    <!-- Right: Terminal Workspace -->
                    <div class="relative group min-h-[450px]">
                        <!-- Main Terminal -->
                        <div
                            class="relative bg-black border border-white/10 rounded-xl overflow-hidden shadow-2xl z-10 h-full"
                        >
                            <!-- Terminal Header -->
                            <div
                                class="flex items-center justify-between px-4 py-2 bg-[#0a0a0a] border-b border-white/5 relative z-10"
                            >
                                <div class="flex gap-1.5">
                                    <div
                                        class="w-3 h-3 rounded-full bg-[#ff5f56]"
                                    >
                                    </div>
                                    <div
                                        class="w-3 h-3 rounded-full bg-[#ffbd2e]"
                                    >
                                    </div>
                                    <div
                                        class="w-3 h-3 rounded-full bg-[#27c93f]"
                                    >
                                    </div>
                                </div>
                                <div
                                    class="text-[10px] text-slate-500 font-mono tracking-widest uppercase"
                                >
                                    sebastian@dev-workspace
                                </div>
                                <div class="w-10"></div>
                            </div>

                            <!-- Terminal Content -->
                            <div
                                class="p-8 text-left font-mono text-[11px] leading-relaxed flex flex-col md:flex-row gap-8 relative z-10 bg-[#0c0c0c] h-full"
                            >
                                <!-- ASCII Art -->
                                <div
                                    class="text-[#00ffa3] whitespace-pre shrink-0 font-bold opacity-90 select-none"
                                >
                                    {
                                        `      _____
     /       \\
    |  () ()  |
     \\   ^   /
      |||||||
      |||||||`
                                    }
                                </div>

                                <!-- System Info -->
                                <div class="space-y-4 flex-1">
                                    <div class="mb-4">
                                        <span class="text-amber-400 font-bold"
                                            >sebastian@dev-workspace</span
                                        >
                                        <div class="text-slate-600 text-[10px]">
                                            ------------------
                                        </div>
                                    </div>

                                    <div
                                        class="grid grid-cols-[100px_1fr] gap-x-4 gap-y-2"
                                    >
                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Status:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-status"
                                        >
                                            Disponible
                                        </div>

                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Áreas:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-areas"
                                        >
                                            Prog | Ciber | Data | IA
                                        </div>

                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Lenguajes:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-languages"
                                        >
                                            Python, JS, SQL
                                        </div>

                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Librerías:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-libraries"
                                        >
                                            Numpy, Pandas, Torch
                                        </div>

                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Frameworks:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-frameworks"
                                        >
                                            React, Next.js, Astro
                                        </div>

                                        <div
                                            class="text-[#00ffa3] font-bold uppercase tracking-tighter"
                                        >
                                            Shell:
                                        </div>
                                        <div
                                            class="text-white"
                                            id="terminal-shell"
                                        >
                                            zsh
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Overlaid Code Window -->
                        <div
                            class="absolute -right-4 -bottom-4 w-[280px] bg-[#0F1117] border border-white/10 rounded-lg shadow-2xl z-20 overflow-hidden hidden lg:block transform hover:translate-x-2 hover:translate-y-2 transition-transform duration-300"
                        >
                            <div
                                class="pl-6 p-5 font-mono text-[10px] text-left leading-relaxed text-slate-300"
                            >
                                <div class="mb-2">
                                    <span class="text-purple-400">import</span> React
                                    <span class="text-purple-400">from</span>
                                    <span class="text-green-400">'react'</span>;
                                </div>
                                <div class="mb-2">
                                    <span class="text-purple-400">const</span>
                                    <span class="text-yellow-300"
                                        >DevWorkspace</span
                                    > = () => &#123;
                                </div>
                                <div class="pl-4 mb-2">
                                    <span class="text-purple-400">const</span> [state,
                                    setState] = useState(<span
                                        class="text-orange-400">true</span
                                    >);
                                </div>
                                <div class="pl-4">
                                    <span class="text-purple-400">return</span> (
                                </div>
                                <div class="pl-8">
                                    &lt;<span class="text-blue-400">div</span> class=<span
                                        class="text-green-400">"dev"</span
                                    > /&gt;
                                </div>
                                <div class="pl-4">);</div>
                                <div>&#125;;</div>
                            </div>
                        </div>

                        <!-- Coffee Status -->
                        <div
                            class="absolute -left-4 -bottom-4 z-30 bg-[#0a0a0a] border border-white/10 rounded-lg px-4 py-2 flex items-center gap-3 shadow-xl transform hover:-translate-y-1 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#f97316"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M17 8h1a4 4 0 1 1 0 8h-1"></path><path
                                    d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"
                                ></path><line x1="6" x2="6" y1="2" y2="4"
                                ></line><line x1="10" x2="10" y1="2" y2="4"
                                ></line><line x1="14" x2="14" y1="2" y2="4"
                                ></line></svg
                            >
                            <span
                                class="text-[9px] font-bold text-slate-400 tracking-widest uppercase"
                                >COFFEE_DEBUGGING</span
                            >
                            <div
                                class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"
                            >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Full Width: Habilidades Especializadas -->
                <div class="lg:col-span-2 mt-8">
                    <div
                        class="flex items-center gap-3 mb-8 relative z-10 px-2"
                    >
                        <div
                            class="p-2.5 bg-[#00ffa3]/10 rounded-xl text-[#00ffa3]"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><polyline points="16 18 22 12 16 6"
                                ></polyline><polyline points="8 6 2 12 8 18"
                                ></polyline></svg
                            >
                        </div>
                        <h4 class="text-lg font-bold text-white">
                            Habilidades Especializadas
                        </h4>
                    </div>

                    <!-- Categorized Tech Grid -->
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10"
                    >
                        {
                            skillCategories.map((category) => (
                                <div class="bg-card p-5 hover:border-[#00ffa3]/30 group">
                                    <div class="space-y-4">
                                        <div class="flex items-center gap-3 text-[#00ffa3]/80 mb-3">
                                            {category.icon === "layout" && (
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="20"
                                                    height="20"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                >
                                                    <rect
