    <style>
        .terminal-cursor {
            display: inline-block;
            width: 8px;
            height: 14px;
            background-color: #00ffa3;
            margin-left: 4px;
            animation: blink 1s step-end infinite;
            vertical-align: middle;
        }

        @keyframes blink {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0;
            }
        }
    </style>

    <script>
        const terminalValues = [
            { id: "terminal-status", text: "Disponible" },
            { id: "terminal-areas", text: "Prog | Ciber | Data | IA" },
            { id: "terminal-languages", text: "Python, JS, SQL" },
            { id: "terminal-libraries", text: "Numpy, Pandas, Torch" },
            { id: "terminal-frameworks", text: "React, Next.js, Astro" },
            { id: "terminal-shell", text: "zsh" },
        ];

        function typeWriter(
            element: HTMLElement,
            text: string,
            speed: number = 40,
        ) {
            let i = 0;
            element.innerHTML = ""; // Start empty
            const cursor = document.createElement("span");
            cursor.className = "terminal-cursor";
            element.appendChild(cursor);

            return new Promise<void>((resolve) => {
                function type() {
                    if (i < text.length) {
                        const charNode = document.createTextNode(
                            text.charAt(i),
                        );
                        element.insertBefore(charNode, cursor);
                        i++;
                        setTimeout(type, speed);
                    } else {
                        cursor.remove(); // Optional: remove cursor when finished
                        resolve();
                    }
                }
                type();
            });
        }

        async function runTerminalAnimation() {
            for (const item of terminalValues) {
                const el = document.getElementById(item.id);
                if (el) {
                    await typeWriter(el, item.text);
                }
            }
        }

        const observerOptions = {
            root: null,
            rootMargin: "0px",
            threshold: 0.1,
        };

        let animationStarted = false;
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting && !animationStarted) {
                    animationStarted = true;
                    runTerminalAnimation();
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        const aboutSection = document.getElementById("about");
        if (aboutSection) {
            observer.observe(aboutSection);
        }
    </script>
