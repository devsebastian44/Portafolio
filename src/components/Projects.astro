---
const projects = [
    {
        title: "Modern Esthete",
        description: "E-commerce full-stack con autenticación de usuarios (login y registro) usando Supabase.",
        image: "/Img/e-commerce.png",
        tags: ["TypeScript", "Next.js", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/Modern-Esthete",
        demo: "https://modernesthete.vercel.app/"
    },
    {
        title: "FintechPro",
        description: "Landing page enfocada en análisis de mercado y herramientas de trading para cripto y activos.",
        image: "/Img/landing-page.png",
        tags: ["Astro", "TypeScript", "Tailwind CSS", "Binance API"],
        github: "https://github.com/Devsebastian44/FintechPro",
        demo: "https://fintechprocripto.netlify.app/"
    },
    {
        title: "DevBlog",
        description: "Blog con enfoque en programación, ciberseguridad y ciencia de datos e IA",
        image: "/Img/devblog.png",
        tags: ["Astro", "TypeScript", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/DevBlog",
        demo: "https://devblog44.vercel.app/"
    },
    {
        title: "CollabData",
        description: "Plataforma colaborativa para el análisis de datos y la visualización de información.",
        image: "/Img/collabdata.png",
        tags: ["Next.js", "TypeScript", "Tailwind CSS", "Firebase"],
        github: "https://github.com/Devsebastian44/CollabData",
        demo: "https://collabdata.vercel.app/"
    },
    {
        title: "Alura Store",
        description: "Análisis de ventas, rendimiento y satisfacción de clientes de las tiendas de Alura Store.",
        image: "/Img/alura.png",
        tags: ["Python", "Pandas", "Matplotlib", "Seaborn"],
        github: "https://github.com/Devsebastian44/Alura-Store",
        demo: "https://colab.research.google.com/github/Devsebastian44/Challenge-Data-Science/blob/master/Challenge_Alura_Latam.ipynb"
    },
    {
        title: "Nextcloud",
        description: "Script para automatizar la instalación y configuración de una nube privada con Nextcloud.",
        image: "/Img/nextcloud.png",
        tags: ["Bash", "Apache", "Ubuntu Server", "MySQL"],
        github: "https://github.com/Devsebastian44/Nextcloud"
    }
];

const techIcons: Record<string, string> = {
    "TypeScript": "simple-icons:typescript",
    "Next.js": "simple-icons:nextdotjs",
    "Tailwind CSS": "simple-icons:tailwindcss",
    "Astro": "simple-icons:astro",
    "Python": "simple-icons:python",
    "Pandas": "simple-icons:pandas",
    "Matplotlib": "lucide:line-chart",
    "Seaborn": "lucide:bar-chart-3",
    "Bash": "simple-icons:gnubash",
    "Apache": "simple-icons:apache",
    "Ubuntu Server": "simple-icons:ubuntu",
    "Linux": "simple-icons:linux",
    "React": "simple-icons:react",
    "PostgreSQL": "simple-icons:postgresql",
    "MySQL": "simple-icons:mysql",
    "Binance API": "simple-icons:binance",
    "Firebase": "simple-icons:firebase"
};
---

<section id="projects" class="py-24 relative overflow-hidden bg-transparent">
    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                Mis <span class="text-[#00ffa3]">Proyectos</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Una colección de mis mejores trabajos, donde la creatividad se une con el código.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            {projects.map((project) => (
                <div class="group bg-card p-8 flex flex-col min-h-[500px]">
                    <!-- Project Image -->
                    <div class="relative aspect-video overflow-hidden -mx-8 -mt-8 mb-8">
                        <img 
                            src={project.image} 
                            alt={project.title}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
                    </div>

                    <!-- Title & Description -->
                    <div class="mb-auto">
                        <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-[#00ffa3] transition-colors tracking-tight">
                            {project.title}
                        </h3>
                        <p class="text-slate-400 text-sm leading-relaxed mb-8 h-12 overflow-hidden italic">
                            {project.description}
                        </p>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-2 mb-8">
                            {project.tags.map((tag) => (
                                <span class="tag-glass">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>

                    <!-- Links -->
                    <div class="flex items-center gap-6">
                        {project.github && (
                            <a href={project.github} target="_blank" class="flex items-center gap-2 text-[12px] font-mono text-slate-500 hover:text-white transition-all group/link" aria-label="Repositorio GitHub">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:scale-110 transition-transform"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                fuente
                            </a>
                        )}
                        {project.demo && (
                            <a href={project.demo} target="_blank" class="flex items-center gap-2 text-[12px] font-mono text-slate-500 hover:text-[#00ffa3] transition-all group/link" aria-label="Demo en vivo">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3] group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform tracking-widest"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                en vivo
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>

        <!-- More Projects Button -->
        <div class="mt-20 flex justify-center relative z-10">
            <a 
                href="https://github.com/Devsebastian44" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group/github flex items-center gap-3 px-10 py-4 bg-white/[0.03] border border-white/10 rounded-2xl text-white hover:border-[#00ffa3]/50 hover:shadow-[0_0_30px_rgba(0,255,163,0.15)] transition-all duration-300 transform hover:-translate-y-1"
            >
                <span class="text-slate-300 group-hover/github:text-white transition-colors uppercase text-xs font-bold tracking-widest">Más proyectos en</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3] group-hover/github:scale-110 transition-transform">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
            </a>
        </div>
    </div>
    
    <!-- Decorative background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#00ffa3]/5 rounded-full blur-[120px] -z-10"></div>
</section>
