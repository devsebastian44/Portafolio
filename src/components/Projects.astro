---
interface Project {
    title: string;
    status: string;
    description: string;
    tags: string[];
    github: string;
    demo?: string;
    projectIcons: { tag: string; icon: string }[];
}

const projects = [
    // Fila 1: Desarrollo Web
    // Fila 1: Desarrollo Web
    {
        title: "Modern Esthete",
        status: "terminado",
        description: "E-commerce full-stack con autenticación de usuarios (login y registro) usando Supabase.",
        tags: ["TypeScript", "Next.js", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/Modern-Esthete",
        demo: "https://modernesthete.vercel.app/"
    },
    {
        title: "CollabData",
        status: "terminado",
        description: "Plataforma colaborativa para el análisis de datos y la visualización de información.",
        tags: ["TypeScript", "Next.js", "Tailwind CSS", "Firebase"],
        github: "https://github.com/Devsebastian44/CollabData",
        demo: "https://collabdata.vercel.app/"
    },
    {
        title: "DevBlog",
        status: "terminado",
        description: "Blog con enfoque en programación, ciberseguridad y ciencia de datos e IA",
        tags: ["Astro", "TypeScript", "Tailwind CSS", "React","PostgreSQL"],
        github: "https://github.com/Devsebastian44/DevBlog",
        demo: "https://devblog44.vercel.app/"
    },
    // Fila 2: Ciencia de Datos
    {
        title: "Alura Store",
        status: "terminado",
        description: "Análisis de ventas, rendimiento y satisfacción de clientes de las tiendas de Alura Store.",
        tags: ["Python", "Pandas", "Matplotlib", "Seaborn"],
        github: "https://github.com/Devsebastian44/Alura-Store",
        demo: "https://github.com/devsebastian44/Alura-Store/blob/main/Challenge_Alura_Latam.ipynb"
    },
    {
        title: "Telecom X",
        status: "terminado",
        description: "Análisis de evasión de clientes para optimizar la retención mediante ciencia de datos.",
        tags: ["Python", "Pandas", "NumPy", "Matplotlib", "Seaborn"],
        github: "https://github.com/devsebastian44/Telecom-X",
        demo: "https://github.com/devsebastian44/Telecom-X/blob/main/TelecomX_LATAM.ipynb"
    },
    {
        title: "Telecom 2",
        status: "terminado",
        description: "Pipeline de Machine Learning para predecir la cancelación de clientes y optimizar la retención.",
        tags: ["Python", "Scikit-learn", "Pandas", "Matplotlib", "Seaborn"],
        github: "https://github.com/devsebastian44/Telecom-2",
        demo: "https://github.com/devsebastian44/Telecom-2/blob/main/TelecomX_Churn_ML.ipynb"
    },
    // Fila 3: Ciberseguridad
    {
        title: "Keylogger",
        status: "terminado",
        description: "Framework educativo para investigación de malware con pipeline DevSecOps y análisis estático de seguridad.",
        tags: ["Python", "DevSecOps", "SAST", "Pytest"],
        github: "https://github.com/devsebastian44/Keylogger"
    },
    {
        title: "Reverse Shell",
        status: "terminado",
        description: "Estrategia de persistencia y acceso remoto para Windows 10 bajo estándares DevSecOps.",
        tags: ["Python", "PowerShell", "DevSecOps", "Windows 10"],
        github: "https://github.com/devsebastian44/Reverse-Shell"
    },
    {
        title: "Sandboxed",
        status: "terminado",
        description: "Menú de herramientas para análisis de malware y virus informáticos en entornos controlados.",
        tags: ["Bash", "Python", "Kali Linux", "REMnux"],
        github: "https://github.com/devsebastian44/Sandboxed"
    }
];

const techIcons: Record<string, string> = {
    "AI/ML": "https://api.iconify.design/mdi/brain.svg?color=white",
    "Browser-Extension": "https://api.iconify.design/mdi/puzzle.svg?color=white",
    "Frontend": "https://api.iconify.design/mdi/web.svg?color=white",
    "Django": "https://cdn.simpleicons.org/django/FFFFFF",
    "Streamlit": "https://cdn.simpleicons.org/streamlit/FFFFFF",
    "WebGL": "https://api.iconify.design/mdi/cube-outline.svg?color=white",
    "GSAP": "https://cdn.simpleicons.org/greensock/FFFFFF",
    "Three.js": "https://cdn.simpleicons.org/threedotjs/FFFFFF",
    "Java": "https://cdn.simpleicons.org/openjdk/FFFFFF",
    "Kotlin": "https://cdn.simpleicons.org/kotlin/FFFFFF",
    "Android": "https://cdn.simpleicons.org/android/FFFFFF",
    "Material-UI": "https://cdn.simpleicons.org/mui/FFFFFF",
    "WebSockets": "https://api.iconify.design/mdi/connection.svg?color=white",
    "TypeScript": "https://cdn.simpleicons.org/typescript/FFFFFF",
    "Next.js": "https://cdn.simpleicons.org/nextdotjs/FFFFFF",
    "Tailwind CSS": "https://cdn.simpleicons.org/tailwindcss/FFFFFF",
    "Astro": "https://cdn.simpleicons.org/astro/FFFFFF",
    "Python": "https://cdn.simpleicons.org/python/FFFFFF",
    "Scikit-learn": "https://cdn.simpleicons.org/scikitlearn/FFFFFF",
    "Pandas": "https://cdn.simpleicons.org/pandas/FFFFFF",
    "Matplotlib": "https://api.iconify.design/devicon-plain/matplotlib.svg?color=white",
    "Seaborn": "https://api.iconify.design/devicon-plain/seaborn.svg?color=white",
    "Bash": "https://cdn.simpleicons.org/gnubash/FFFFFF",
    "Ubuntu Server": "https://cdn.simpleicons.org/ubuntu/FFFFFF",
    "Linux": "https://cdn.simpleicons.org/linux/FFFFFF",
    "React": "https://cdn.simpleicons.org/react/FFFFFF",
    "PostgreSQL": "https://cdn.simpleicons.org/postgresql/FFFFFF",
    "MySQL": "https://cdn.simpleicons.org/mysql/FFFFFF",
    "Firebase": "https://cdn.simpleicons.org/firebase/FFFFFF",
    "NumPy": "https://cdn.simpleicons.org/numpy/FFFFFF",
    "DevSecOps": "https://api.iconify.design/mdi/shield-check.svg?color=white",
    "PowerShell": "https://api.iconify.design/simple-icons/powershell.svg?color=white",
    "SAST": "https://api.iconify.design/mdi/magnify-scan.svg?color=white",
    "Pytest": "https://cdn.simpleicons.org/pytest/FFFFFF",
    "Windows 10": "https://api.iconify.design/simple-icons/windows.svg?color=white",
    "Kali Linux": "https://cdn.simpleicons.org/kalilinux/FFFFFF",
    "REMnux": "https://api.iconify.design/mdi/virus-outline.svg?color=white",
    "CI/CD": "https://cdn.simpleicons.org/gitlab/FFFFFF"
};

const projectsWithIcons: Project[] = projects.map(project => {
    const projectIcons: { tag: string; icon: string }[] = [];
    const seenIcons = new Set<string>();
    project.tags.forEach(tag => {
        const icon = techIcons[tag];
        if (icon && !seenIcons.has(icon)) {
            seenIcons.add(icon);
            projectIcons.push({ tag, icon });
        }
    });
    return { ...project, projectIcons } as Project;
});
---

<section id="projects" class="py-24 relative bg-transparent">
    <!-- Projects Background Glow -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] h-[600px] bg-[#00ffa3]/5 blur-[120px] rounded-full pointer-events-none z-0"
    >
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-6xl font-bold text-white mb-4 flex items-center justify-center gap-2">
                Mis <span class="text-[#00ffa3]">Proyectos</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Una colección de mis mejores trabajos, donde la creatividad se une con el código.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            {projectsWithIcons.map((project, index) => (
                <div class="group relative bg-white/[0.02] backdrop-blur-xl border border-white/10 rounded-xl p-7 flex flex-col gap-4 transition-all duration-300 hover:border-[#00ffa3]/30 hover:bg-white/[0.04] hover:shadow-[0_0_30px_rgba(0,255,163,0.05)] overflow-hidden">
                    <!-- Window Controls -->
                    <div class="flex items-center gap-1.5 mb-2 opacity-50 group-hover:opacity-100 transition-opacity">
                        <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
                        <span class="ml-2 text-[10px] font-mono text-slate-500 uppercase tracking-widest">{project.title.toLowerCase()}.exe</span>
                    </div>

                    <!-- Tech background subtle deco -->
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity pointer-events-none">
                         <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>
                    </div>

                    <!-- Content -->
                    <div class="relative z-10 space-y-3">
                        <div class="flex items-center justify-between">
                            <h3 class="text-xl md:text-2xl font-bold text-white tracking-tight group-hover:text-[#00ffa3] transition-colors leading-tight">
                                {project.title}
                            </h3>
                            <div class="flex items-center gap-2 px-2 py-0.5 bg-[#00ffa3]/5 border border-[#00ffa3]/10 rounded-full">
                                <div class="w-1.5 h-1.5 rounded-full bg-[#00ffa3] animate-pulse"></div>
                                <span class="text-[8px] font-mono text-[#00ffa3] font-bold uppercase tracking-wider">{project.status}</span>
                            </div>
                        </div>
                        <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 group-hover:line-clamp-none transition-all duration-500">
                            {project.description}
                        </p>
                    </div>

                    <div class="mt-auto space-y-4 pt-4 border-t border-white/5 relative z-10">
                        <!-- Tech Icons -->
                        <div class="flex flex-wrap gap-3">
                            {project.projectIcons.map(({ tag, icon }) => (
                                <div class="group/tech relative w-6 h-6 flex items-center justify-center">
                                    <img 
                                        src={icon} 
                                        alt={tag}
                                        class="w-5 h-5 object-contain opacity-60 hover:opacity-100 transition-all duration-300 transform hover:scale-110 grayscale brightness-[300%]"
                                        title={tag}
                                    />
                                </div>
                            ))}
                        </div>

                        <!-- Action Links -->
                        <div class="flex items-center gap-6">
                            {project.github && (
                                <a href={project.github} target="_blank" class="flex items-center gap-2 text-xs md:text-sm font-mono text-slate-500 hover:text-white transition-all group/link" aria-label="Repositorio GitHub">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:text-[#00ffa3] transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                    fuente
                                </a>
                            )}
                            {project.demo && (
                                <a href={project.demo} target="_blank" class="flex items-center gap-2 text-xs md:text-sm font-mono text-white/70 hover:text-white transition-all group/link relative" aria-label="Demo en vivo">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                    demo en vivo
                                </a>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- More Projects Button -->
        <div class="mt-20 flex justify-center relative z-10">
            <a 
                href="https://github.com/Devsebastian44" 
                target="_blank" 
                rel="noopener noreferrer"
                class="btn-exe group/github"
            >
                <span class="relative z-10">GITHUB_PROYECTOS.EXE</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/github:rotate-12 transition-transform">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
            </a>
        </div>
    </div>
    
    <!-- Decorative background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[1000px] h-[1000px] bg-[#00ffa3]/5 rounded-full blur-[150px] md:blur-[200px] -z-10"></div>
</section>
