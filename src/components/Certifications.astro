---
const certifications = [
    {
        title: "Linux Essentials",
        issuer: "Cisco",
        date: "Jul 2025",
        url: "https://www.credly.com/badges/46f4abdc-63fb-4a58-9030-c0ea06557041",
        icon: "simple-icons:cisco"
    },
    {
        title: "Agile Explorer",
        issuer: "IBM",
        date: "Sep 2025",
        url: "https://www.credly.com/badges/ae281b27-f0b2-446e-9889-d0e0c1fdf042",
        icon: "simple-icons:ibm"
    },
    {
        title: "AWS Knowledge: Security Champion",
        issuer: "Amazon Web Services",
        date: "Jul 2025",
        url: "https://www.credly.com/badges/60dacd05-38d2-4f94-a3d7-9dec61900846",
        icon: "simple-icons:amazonaws"
    },
    {
        title: "Getting Started with Cybersecurity",
        issuer: "IBM",
        date: "Sep 2025",
        url: "https://www.credly.com/badges/95d0d024-b94a-491f-9f2a-6b007f81dc0e",
        icon: "simple-icons:ibm"
    },
    {
        title: "Artificial Intelligence Fundamentals",
        issuer: "IBM",
        date: "Sep 2025",
        url: "https://www.credly.com/badges/d757c44a-3683-402b-9400-55c59817a115",
        icon: "simple-icons:ibm"
    },
    {
        title: "Big Data Foundations - Level 2",
        issuer: "IBM",
        date: "Jul 2025",
        url: "https://www.credly.com/badges/0522cc77-78d1-4b8f-ba82-c0526162af18",
        icon: "simple-icons:ibm"
    }
];
---

<section id="certifications" class="py-24 relative bg-transparent">
    <!-- Certifications Background Glow -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-[#00ffa3]/5 blur-[100px] rounded-full pointer-events-none z-0"
    >
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                Mis <span class="text-[#00ffa3]">Certificaciones</span>
            </h2>
            <p class="text-slate-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Validando conocimientos y expandiendo horizontes en tecnología.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            {certifications.map((cert) => (
                <div class="group relative bg-white/[0.02] backdrop-blur-xl border border-white/10 rounded-2xl p-8 flex flex-col gap-6 transition-all duration-300 hover:border-[#00ffa3]/30 hover:bg-white/[0.04] hover:shadow-[0_0_30px_rgba(0,255,163,0.05)] overflow-hidden">
                    
                    <!-- Decorative corner element -->
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity">
                         <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#00ffa3" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                    </div>

                    <!-- Header Row: Date & Icon -->
                    <div class="flex items-center justify-between relative z-10">
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#00ffa3] group-hover:bg-[#00ffa3]/10 transition-colors">
                            <iconify-icon icon={cert.icon} width="20" height="20"></iconify-icon>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 rounded-full">
                            <span class="text-[10px] font-mono text-slate-400 font-bold tracking-wider">{cert.date}</span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="relative z-10 space-y-2 flex-grow">
                        <h3 class="text-xl font-bold text-white tracking-tight group-hover:text-[#00ffa3] transition-colors leading-tight">
                            {cert.title}
                        </h3>
                        <p class="text-slate-400 text-sm font-mono tracking-wide">
                            {cert.issuer}
                        </p>
                    </div>

                    <!-- Action Link -->
                    <div class="pt-4 mt-auto relative z-10 border-t border-white/5">
                        <a href={cert.url} target="_blank" class="flex items-center justify-between w-full text-[11px] font-mono text-slate-500 hover:text-white transition-all group/link" aria-label="Ver credencial">
                            <span>ver_credencial</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:text-[#00ffa3] group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-all"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
                        </a>
                    </div>
                </div>
            ))}
        </div>

        <!-- More Certifications Button -->
        <div class="mt-20 flex justify-center relative z-10">
            <a 
                href="https://www.credly.com/users/devsebastian44/badges" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group/credly flex items-center gap-3 px-10 py-4 bg-white/[0.03] border border-white/10 rounded-2xl text-white hover:border-[#00ffa3]/50 hover:shadow-[0_0_30px_rgba(0,255,163,0.15)] transition-all duration-300 transform hover:-translate-y-1"
            >
                <span class="text-slate-300 group-hover/credly:text-white transition-colors uppercase text-xs font-bold tracking-widest">Ver más en Credly</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00ffa3] group-hover/credly:scale-110 transition-transform">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
            </a>
        </div>
    </div>
</section>
